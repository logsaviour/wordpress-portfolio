</Layout>

<script>
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	// Watermark Parallax Logic
	const watermark = document.getElementById('watermark');
	if (watermark) {
		gsap.to(watermark, {
			xPercent: -50,
			ease: "none",
			scrollTrigger: {
				trigger: document.body,
				start: "top top",
				end: "bottom bottom",
				scrub: 1, 
			}
		});
	}

	// 1. Initial Load Drop-in Animation for the Name
	gsap.fromTo(".name-char", 
		{ y: -20, opacity: 0 },
		{ y: 0, opacity: 1, duration: 0.6, stagger: 0.05, ease: "power3.out", delay: 0.5 }
	);

	// 2. Hover Wave Animation for the Name
	const brandName = document.getElementById('brand-name');
	if (brandName) {
		brandName.addEventListener('mouseenter', () => {
			gsap.to(".name-char", {
				y: -6,
				color: "#2dd4bf", // Flashes teal
				stagger: 0.04,
				duration: 0.2,
				yoyo: true,
				repeat: 1,
				ease: "power2.out"
			});
		});
	}

	// Staggered Scatter & Scrub Logic for Project Cards
	const projectCards = document.querySelectorAll('.project-card');
	
	projectCards.forEach((card, index) => {
		const xOffset = index % 2 === 0 ? 100 : -100;
		const rotOffset = index % 2 === 0 ? 8 : -8;

		gsap.fromTo(card, 
			{ 
				opacity: 0, 
				y: 200, 
				x: xOffset, 
				rotation: rotOffset,
				scale: 0.95
			},
			{
				opacity: 1,
				y: 0,
				x: 0,
				rotation: 0,
				scale: 1,
				ease: "none",
				scrollTrigger: {
					trigger: card,
					start: "top 95%", 
					end: "top 65%",   
					scrub: 1 
				}
			}
		);
	});
</script>
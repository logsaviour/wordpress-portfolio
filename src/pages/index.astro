---
import Layout from '../layouts/Layout.astro';
import InteractiveLogo from '../components/InteractiveLogo';
import ScrollSection from '../components/ScrollSection.astro';
import { LayoutTemplate, Zap, Database, ArrowUpRight, Mail, Eye } from 'lucide-react';
---

<Layout 
	title="Ali Hassan | Custom WordPress Architect" 
	description="Senior Custom WordPress Developer engineering high-performance headless architecture and frontend ecosystems."
>
	<div class="fixed top-[20%] left-0 w-[200vw] pointer-events-none z-0 opacity-5">
		<h1 id="watermark" class="text-[15rem] font-bold tracking-tighter whitespace-nowrap text-white">
			WORDPRESS &nbsp;&nbsp;&nbsp; WORDPRESS &nbsp;&nbsp;&nbsp; WORDPRESS &nbsp;&nbsp;&nbsp; WORDPRESS &nbsp;&nbsp;&nbsp;
		</h1>
	</div>

	<div class="fixed right-4 top-1/2 -translate-y-1/2 text-zinc-600 tracking-[0.3em] text-[0.65rem] font-mono hidden md:block pointer-events-none z-50 whitespace-nowrap" style="writing-mode: vertical-rl; transform: rotate(180deg);">
		FRONTEND ENGINEER // CUSTOM ARCHITECTURE
	</div>

	<nav class="fixed top-0 left-0 w-full z-50 px-6 py-4 flex justify-between items-center mix-blend-difference">
		<InteractiveLogo client:load />

		<div class="flex gap-6 items-center">
			<a href="/elementor" class="magnetic-btn hidden lg:flex items-center space-x-2 mr-4 text-sm font-medium text-zinc-400 hover:text-teal-400 transition-colors group">
				<span class="tracking-[0.1em]">Elementor Architecture</span>
				<ArrowUpRight class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" />
			</a>
			<a href="mailto:aliha85234@gmail.com" class="magnetic-btn text-sm font-medium text-zinc-400 hover:text-white transition-colors flex items-center gap-2 hidden sm:flex">
				<Mail class="w-4 h-4" /> Let's Talk
			</a>
			<a href="https://www.upwork.com/freelancers/~013d2ca8734e3f8ffc?mp_source=share" target="_blank" rel="noreferrer" class="magnetic-btn px-4 py-2 bg-teal-500 hover:bg-teal-400 text-zinc-950 text-sm font-bold rounded-full transition-colors">
				Hire on Upwork
			</a>
		</div>
	</nav>

	<ScrollSection id="hero" className="border-b border-zinc-900 bg-transparent z-10">
		<div class="space-y-6 pt-20">
			<div class="inline-flex items-center gap-2 px-3 py-1 text-xs font-mono bg-zinc-900 border border-zinc-800 rounded-full text-teal-400 overflow-hidden">
				<span class="hero-reveal-element flex items-center gap-2">
					<span class="w-2 h-2 rounded-full bg-teal-400 animate-pulse"></span> Available on Upwork
				</span>
			</div>
			
			<h1 class="text-5xl md:text-8xl font-bold tracking-tight bg-gradient-to-r from-zinc-100 via-zinc-400 to-zinc-600 bg-clip-text text-transparent">
				<div class="overflow-hidden"><span class="block hero-text-line">Custom WordPress</span></div>
				<div class="overflow-hidden"><span class="block hero-text-line">Architecture.</span></div>
			</h1>
			
			<div class="overflow-hidden max-w-xl">
				<p class="hero-reveal-element text-zinc-400 text-lg font-light leading-relaxed">
					Hi, I'm Ali Hassan. I engineer high-performance headless WordPress themes and custom frontend ecosystems that load instantly and scale globally.
				</p>
			</div>
		</div>
	</ScrollSection>

	<ScrollSection id="architecture" className="bg-transparent border-b border-zinc-900 z-10">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
			<!-- Architecture Features (Unchanged structure, retaining data) -->
			<div class="p-8 border border-zinc-900 bg-zinc-950/80 backdrop-blur-md rounded-2xl space-y-4 hover:border-teal-500/50 transition-colors">
				<LayoutTemplate class="w-8 h-8 text-sky-400" />
				<h3 class="text-xl font-semibold text-white">Custom Theme Dev</h3>
				<p class="text-zinc-400 text-sm leading-relaxed">Building bespoke WordPress themes from scratch without bloated page builders, ensuring pixel-perfect design translation.</p>
			</div>
			<div class="p-8 border border-zinc-900 bg-zinc-950/80 backdrop-blur-md rounded-2xl space-y-4 hover:border-teal-500/50 transition-colors">
				<Zap class="w-8 h-8 text-teal-400" />
				<h3 class="text-xl font-semibold text-white">Headless Ecosystems</h3>
				<p class="text-zinc-400 text-sm leading-relaxed">Decoupling the WordPress CMS via REST API or GraphQL to feed lightning-fast frontend frameworks like React and Svelte.</p>
			</div>
			<div class="p-8 border border-zinc-900 bg-zinc-950/80 backdrop-blur-md rounded-2xl space-y-4 hover:border-teal-500/50 transition-colors">
				<Database class="w-8 h-8 text-purple-400" />
				<h3 class="text-xl font-semibold text-white">Advanced Data Structuring</h3>
				<p class="text-zinc-400 text-sm leading-relaxed">Expert implementation of Custom Post Types (CPTs) and Advanced Custom Fields (ACF) for complex enterprise content.</p>
			</div>
		</div>
	</ScrollSection>

	<ScrollSection id="projects" className="bg-transparent z-10 py-24">
		<div class="w-full space-y-24">
			<div class="border-b border-zinc-900 pb-6 mb-12">
				<h2 class="text-3xl font-bold tracking-tight text-white">Featured Deployments</h2>
			</div>
			
			<!-- Project 1 -->
			<div class="project-card group border border-zinc-900 p-8 rounded-2xl bg-zinc-950/80 backdrop-blur-md hover:bg-zinc-900/50 hover:border-teal-900/50 transition-all duration-500 flex flex-col md:flex-row gap-12 items-center">
				<a href="https://atelierdesignny.com/" target="_blank" class="w-full md:w-1/2 bg-zinc-900 rounded-xl border border-zinc-800 overflow-hidden relative group-hover:border-teal-500/80 transition-all duration-500 shadow-2xl block cursor-none">
					<img src="/images/atelier.jpg" alt="Atelier Design NY" class="w-full h-auto object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 ease-out" />
					<div class="absolute inset-0 bg-zinc-950/40 backdrop-blur-[2px] opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center z-10">
						<span class="px-5 py-2.5 bg-zinc-900/90 border border-teal-500/50 rounded-full text-white text-sm font-medium flex items-center gap-2 translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
							<Eye class="w-4 h-4 text-teal-400" /> View Deployment
						</span>
					</div>
				</a>
				<div class="w-full md:w-1/2 space-y-4">
					<span class="text-xs font-mono text-teal-400 tracking-wider">CREATIVE AGENCY UI</span>
					<h4 class="text-3xl md:text-4xl font-bold text-zinc-100">Atelier Design NY</h4>
					<p class="text-zinc-400 text-sm md:text-base leading-relaxed">A high-fidelity, pixel-perfect custom WordPress build for a New York design firm. Focused on fluid typography, advanced media handling, and a zero-clutter admin backend.</p>
				</div>
			</div>

			<!-- Project 2 -->
			<div class="project-card group border border-zinc-900 p-8 rounded-2xl bg-zinc-950/80 backdrop-blur-md hover:bg-zinc-900/50 hover:border-sky-900/50 transition-all duration-500 flex flex-col md:flex-row-reverse gap-12 items-center">
				<a href="https://candihealth.com/" target="_blank" class="w-full md:w-1/2 bg-zinc-900 rounded-xl border border-zinc-800 overflow-hidden relative group-hover:border-sky-500/80 transition-all duration-500 shadow-2xl block cursor-none">
					<img src="/images/candi.jpg" alt="Candi Health" class="w-full h-auto object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 ease-out" />
					<div class="absolute inset-0 bg-zinc-950/40 backdrop-blur-[2px] opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center z-10">
						<span class="px-5 py-2.5 bg-zinc-900/90 border border-sky-500/50 rounded-full text-white text-sm font-medium flex items-center gap-2 translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
							<Eye class="w-4 h-4 text-sky-400" /> View Deployment
						</span>
					</div>
				</a>
				<div class="w-full md:w-1/2 space-y-4">
					<span class="text-xs font-mono text-sky-400 tracking-wider">HEALTHCARE INFRASTRUCTURE</span>
					<h4 class="text-3xl md:text-4xl font-bold text-zinc-100">Candi Health</h4>
					<p class="text-zinc-400 text-sm md:text-base leading-relaxed">A secure, highly professional corporate architecture designed for the healthcare sector. Engineered for high accessibility scores, rapid load times, and seamless user routing.</p>
				</div>
			</div>

		</div>
	</ScrollSection>
</Layout>

<script>
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	document.addEventListener('astro:page-load', () => {
		// Kill existing triggers to prevent memory leaks on SPA routing
		ScrollTrigger.getAll().forEach(t => t.kill());

		// 1. Watermark Parallax Logic
		const watermark = document.getElementById('watermark');
		if (watermark) {
			gsap.to(watermark, {
				xPercent: -50,
				ease: "none",
				scrollTrigger: {
					trigger: document.body,
					start: "top top",
					end: "bottom bottom",
					scrub: 1, 
				}
			});
		}

		// 2. Advanced Hero Text Mask-Up Reveal Timeline
		const heroTl = gsap.timeline();
		heroTl.fromTo(".hero-text-line", 
			{ y: 100, opacity: 0, skewY: 5 },
			{ y: 0, opacity: 1, skewY: 0, duration: 1.2, stagger: 0.15, ease: "power4.out", delay: 0.2 }
		).fromTo(".hero-reveal-element",
			{ y: 20, opacity: 0 },
			{ y: 0, opacity: 1, duration: 0.8, stagger: 0.1, ease: "power2.out" },
			"-=0.8"
		);

		// 3. Staggered Scatter & Scrub Logic for Project Cards
		const projectCards = document.querySelectorAll('.project-card');
		projectCards.forEach((card, index) => {
			const xOffset = index % 2 === 0 ? 50 : -50;

			gsap.fromTo(card, 
				{ opacity: 0, y: 150, x: xOffset, scale: 0.98 },
				{
					opacity: 1, y: 0, x: 0, scale: 1,
					ease: "power2.out",
					scrollTrigger: {
						trigger: card,
						start: "top 90%", 
						end: "top 60%",   
						scrub: 1 
					}
				}
			);
		});
	});
</script>
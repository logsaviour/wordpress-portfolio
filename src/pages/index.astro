---
import Layout from '../layouts/Layout.astro';
import InteractiveLogo from '../components/InteractiveLogo';
import ScrollSection from '../components/ScrollSection.astro';
import { LayoutTemplate, Zap, Database, ArrowUpRight, Mail } from 'lucide-react';
---

<Layout 
	title="Ali Hassan | Custom WordPress Architect" 
	description="Senior Custom WordPress Developer engineering high-performance headless architecture and frontend ecosystems."
>
	<div class="fixed top-[20%] left-0 w-[200vw] pointer-events-none z-0 opacity-5">

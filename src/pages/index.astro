			<div class="project-card group border border-zinc-900 p-8 rounded-2xl bg-zinc-950/80 backdrop-blur-md hover:bg-zinc-900/50 transition-all flex flex-col md:flex-row gap-8 items-center mt-4">
				<div class="w-full md:w-1/2 bg-zinc-900 rounded-xl border border-zinc-800 overflow-hidden relative group-hover:border-emerald-400/50 transition-colors shadow-2xl">
					<img src="/images/donatefy.jpg" alt="Donatefy" class="w-full h-auto object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 ease-out" />
				</div>
				<div class="w-full md:w-1/2 space-y-4">

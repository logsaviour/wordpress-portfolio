		</h1>
	</div>

	<div class="fixed right-4 top-1/2 -translate-y-1/2 text-zinc-600 tracking-[0.3em] text-[0.65rem] font-mono hidden md:block pointer-events-none z-50 whitespace-nowrap" style="writing-mode: vertical-rl; transform: rotate(180deg);">
		FRONTEND ENGINEER // CUSTOM ARCHITECTURE
	</div>

	<nav class="fixed top-0 left-0 w-full z-50 px-6 py-4 flex justify-between items-center mix-blend-difference">
		<InteractiveLogo client:load />

		<div class="flex gap-6 items-center">
			
			<div id="brand-name" class="hidden lg:flex items-center space-x-[2px] mr-6 cursor-pointer overflow-hidden">
				<span class="name-char text-white font-bold tracking-[0.15em] text-sm">A</span>
				<span class="name-char text-white font-bold tracking-[0.15em] text-sm">L</span>
				<span class="name-char text-white font-bold tracking-[0.15em] text-sm">I</span>
				<span class="w-3"></span> <span class="name-char text-white font-bold tracking-[0.15em] text-sm">H</span>
				<span class="name-char text-white font-bold tracking-[0.15em] text-sm">A</span>
				<span class="name-char text-white font-bold tracking-[0.15em] text-sm">S</span>
				<span class="name-char text-white font-bold tracking-[0.15em] text-sm">S</span>
				<span class="name-char text-white font-bold tracking-[0.15em] text-sm">A</span>
				<span class="name-char text-white font-bold tracking-[0.15em] text-sm">N</span>
			</div>

			<!-- Elementor Route Added Here -->
			<a href="/elementor" class="hidden lg:flex items-center space-x-2 mr-4 text-sm font-medium text-zinc-400 hover:text-teal-400 transition-colors group">
				<span class="tracking-[0.1em]">Elementor Architecture</span>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</a>

			<a href="mailto:aliha85234@gmail.com" class="text-sm font-medium text-zinc-400 hover:text-white transition-colors flex items-center gap-2 hidden sm:flex">
				<Mail class="w-4 h-4" /> Let's Talk
			</a>
			<a href="https://www.upwork.com/freelancers/~013d2ca8734e3f8ffc?mp_source=share" target="_blank" rel="noreferrer" class="px-4 py-2 bg-teal-500 hover:bg-teal-400 text-zinc-950 text-sm font-bold rounded-full transition-colors">
				Hire on Upwork
			</a>
		</div>
	</nav>

	<ScrollSection id="hero" className="border-b border-zinc-900 bg-transparent z-10">
		<div class="space-y-6 pt-20">
			<div class="inline-flex items-center gap-2 px-3 py-1 text-xs font-mono bg-zinc-900 border border-zinc-800 rounded-full text-teal-400">
